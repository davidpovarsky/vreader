# Test books (local only)
test-books/

# Claude Code local-only artifacts (personal, not shared across the team)
# - settings.local.json: per-user permission allowlist
# - *.local.{md,json,yaml,yml}: any file that opts in to local-only via the
#   `.local.` infix (Claude Code convention)
# - tdd-guardian/state.json: per-run TDD state, regenerated on each invocation
.claude/settings.local.json
.claude/*.local.json
.claude/*.local.md
.claude/*.local.yaml
.claude/*.local.yml
.claude/state.json
.claude/tdd-guardian/state.json
# Cron / loop runtime locks (per-session)
.claude/scheduled_tasks.lock

# Tokenize / inspection scratch
.tokenize/

# Secrets — local API keys, never commit
.secrets/

# >>> cc-suite >>>
# AI assistant local state
.claude/settings.local.json
.claude/CLAUDE.local.md
.claude/*.local.*
CLAUDE.local.md

# Codex CLI — local files, keep checked-in subdirs
.codex/*
!.codex/skills/
!.codex/prompts/
!.codex/hooks.json
!.codex/hooks.cc-suite.json
!.codex/config.toml

# Gemini CLI — local files, keep checked-in subdirs
.gemini/*
!.gemini/skills/
!.gemini/commands/
# <<< cc-suite <<<

# cc-suite local bridge symlinks — per-machine, regenerated by `/cc-suite:init`
# (the .claude one is an absolute, cc-suite-version-pinned path; never commit).
.claude/skills/cc-suite
.agents/

# Android (feature #106) — build artifacts + local SDK config (the gradle
# wrapper jar IS committed; build/ is already ignored above).
android/.gradle/
android/local.properties
android/app/build/
.gradle/
