{
    "bookSourceUrl": "https://www.example-novel.com",
    "bookSourceName": "示例小说网",
    "bookSourceGroup": "中文小说",
    "bookSourceType": 0,
    "enabled": true,
    "searchUrl": "https://www.example-novel.com/search?q={{key}}",
    "header": "{\"User-Agent\": \"Mozilla/5.0\"}",
    "ruleSearch": {
        "bookList": "div.result-list div.item",
        "name": "h3.title",
